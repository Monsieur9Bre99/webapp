{
	"arrowParens": "always",
	"bracketSameLine": true,
	"bracketSpacing": true,
	"endOfLine": "auto",
	"experimentalOperatorPosition": "start",
	"jsxSingleQuote": true,
	"objectWrap": "collapse",
	"semi": true,
	"singleAttributePerLine": true,
	"singleQuote": true,
	"tabWidth": 3,
	"trailingComma": "all",
	"useTabs": true
}
